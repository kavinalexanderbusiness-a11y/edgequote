# ── EdgeQuote environment variables ───────────────────────────────────────────
# Copy the ones you need into .env.local (dev) and your Vercel project (prod).

# Supabase (REQUIRED — already in use)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Google Maps (geocoding / routing — already in use)
GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_BROWSER_KEY=

# App URL — used to build customer portal links inside server-sent messages.
# (In the browser the current origin is used automatically.)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# ── Communications (OPTIONAL — sending stays DISABLED until these are set) ──────
# SMS via Twilio. Requires a Twilio number + A2P 10DLC registration for business
# texting in the US/CA.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=          # e.g. +15875551234

# Email via Resend. Requires a verified sending domain.
RESEND_API_KEY=
RESEND_FROM=          # e.g. "Edge Property Services <hello@yourdomain.com>"

# Scheduled sends (Vercel Cron → /api/cron/notifications, see vercel.json).
# CRON_SECRET: set this and Vercel auto-sends it as a Bearer token the route
#   validates (so only Vercel's scheduler can trigger it).
# SUPABASE_SERVICE_ROLE_KEY: lets the cron read across customers. KEEP SERVER-ONLY
#   — never expose with a NEXT_PUBLIC_ prefix.
CRON_SECRET=
SUPABASE_SERVICE_ROLE_KEY=

# ── Stripe payments (hosted Checkout) — leave blank to keep Pay Now disabled ──
# ── AI generation (Grow > Marketing Studio) — leave blank to keep AI DISABLED ──
# Anthropic / Claude. Powers marketing copy generation (posts, captions, ads).
# Server-only — NEVER expose with a NEXT_PUBLIC_ prefix. Without it the Studio
# shows a "connect AI" state and generates nothing; everything else still works.
# Get a key at https://console.anthropic.com → API Keys.
ANTHROPIC_API_KEY=

STRIPE_SECRET_KEY=
# From the Stripe dashboard → Developers → Webhooks → your endpoint signing secret
STRIPE_WEBHOOK_SECRET=

# ── Web Push notifications (PWA) — leave blank to keep push DISABLED ──────────
# Generate the key pair ONCE with:  npx web-push generate-vapid-keys
# The PUBLIC key is exposed to the browser (NEXT_PUBLIC_), the PRIVATE key is
# server-only. VAPID_SUBJECT is a mailto: or https: contact for push services.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@yourdomain.com
# Shared secret the DB push trigger sends with each /api/push/send call. Must match
# the value you set in public.push_config.secret (see schema.sql migration 2026-06-24c).
PUSH_SEND_SECRET=
