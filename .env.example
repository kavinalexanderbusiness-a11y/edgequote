# ── EdgeQuote environment variables ───────────────────────────────────────────
# Copy the ones you need into .env.local (dev) and your Vercel project (prod).

# Supabase (REQUIRED — already in use)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Google Maps (geocoding / routing — already in use)
GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_BROWSER_KEY=

# App URL — used to build customer portal links inside server-sent messages.
# (In the browser the current origin is used automatically.)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# ── Communications (OPTIONAL — sending stays DISABLED until these are set) ──────
# SMS via Twilio. Requires a Twilio number + A2P 10DLC registration for business
# texting in the US/CA.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=          # e.g. +15875551234

# Email via Resend. Requires a verified sending domain.
RESEND_API_KEY=
RESEND_FROM=          # e.g. "Edge Property Services <hello@yourdomain.com>"

# Scheduled sends (Vercel Cron → /api/cron/notifications, see vercel.json).
# CRON_SECRET: set this and Vercel auto-sends it as a Bearer token the route
#   validates (so only Vercel's scheduler can trigger it).
# SUPABASE_SERVICE_ROLE_KEY: lets the cron read across customers. KEEP SERVER-ONLY
#   — never expose with a NEXT_PUBLIC_ prefix.
CRON_SECRET=
SUPABASE_SERVICE_ROLE_KEY=
